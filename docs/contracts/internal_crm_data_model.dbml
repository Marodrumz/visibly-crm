  expires_at datetime(6)

  indexes {
    (state, created_at_source)
    (expires_at, state)
  }
  Note: "Backup set inventory and verification state"
}

Table restore_drills {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  backup_record_id bigint [not null]
  release_id bigint
  state varchar(24) [not null]
  started_at datetime(6) [not null]
  ended_at datetime(6)
  measured_rpo_seconds bigint
  measured_rto_seconds bigint
  reconciliation_json longtext
  evidence_file_id bigint
  performed_by_id bigint [not null]
  approved_by_id bigint
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (state, started_at)
    (backup_record_id, started_at)
  }
  Note: "Timed restore drill and reconciliation evidence"
}

