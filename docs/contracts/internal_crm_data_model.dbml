// Internal CRM + Automation + Local AI - production logical schema
// Optimized for one company, <=11 staff, MySQL/MariaDB, and a 500 MB database ceiling.
// Polymorphic object_type/object_id references are enforced by domain services and integrity jobs.

Table users {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  email_normalized varchar(254) [unique, not null]
  email_display varchar(254) [not null]
  password_hash varchar(255) [not null]
  user_kind varchar(16) [not null]
  status varchar(24) [not null]
  full_name varchar(160) [not null]
  preferred_timezone varchar(64)
  last_login_at datetime(6)
  must_change_password boolean [not null, default: false]
  auth_epoch int [not null, default: 1]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  deleted_at datetime(6)
  deleted_by_id bigint

  indexes {
    (status, user_kind)
    (last_login_at)
  }
  Note: "Immutable staff or portal identity and account state"
}

Table staff_invitations {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  token_hash char(64) [unique, not null]
  email_normalized varchar(254) [not null]
  issued_by_id bigint [not null]
  role_snapshot_json text [not null]
  expires_at datetime(6) [not null]
  accepted_at datetime(6)
  revoked_at datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (email_normalized, expires_at)
    (expires_at, accepted_at)
  }
  Note: "Single-use staff invitation"
}

Table portal_invitations {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  token_hash char(64) [unique, not null]
  contact_id bigint [not null]
  organization_id bigint [not null]
  issued_by_id bigint [not null]
  expires_at datetime(6) [not null]
  accepted_at datetime(6)
  revoked_at datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (organization_id, contact_id)
    (expires_at, accepted_at)
  }
  Note: "Single-use portal invitation bound to contact and organization"
}

Table mfa_devices {
  id bigint [pk, increment]
  user_id bigint [not null]
  name varchar(80) [not null]
  secret_ciphertext text [not null]
  key_version varchar(32) [not null]
  confirmed_at datetime(6)
  last_used_step bigint
  disabled_at datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (user_id, disabled_at)
  }
  Note: "TOTP devices for staff identities"
}

Table mfa_recovery_codes {
  id bigint [pk, increment]
  user_id bigint [not null]
  code_hash char(64) [unique, not null]
  used_at datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (user_id, used_at)
  }
  Note: "Hashed single-use MFA recovery codes"
}

Table user_sessions {
  id bigint [pk, increment]
  session_key_hash char(64) [unique, not null]
  user_id bigint [not null]
  device_summary varchar(255)
  ip_prefix varchar(64)
  user_agent_hash char(64)
  last_seen_at datetime(6) [not null]
  absolute_expires_at datetime(6) [not null]
  revoked_at datetime(6)
  revoked_reason varchar(120)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (user_id, revoked_at)
    (absolute_expires_at)
  }
  Note: "Revocable server-side session inventory"
}

Table roles {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  code varchar(64) [not null]
  name varchar(120) [not null]
  version int [not null]
  status varchar(20) [not null]
  scope_ceiling varchar(24) [not null]
  effective_from datetime(6) [not null]
  effective_to datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (code, version) [unique]
    (status, effective_from)
  }
  Note: "Versioned role bundle"
}

Table capabilities {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  code varchar(96) [unique, not null]
  name varchar(160) [not null]
  risk_class varchar(24) [not null]
  description text [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  Note: "Atomic authorization capability registry"
}

Table role_capabilities {
  id bigint [pk, increment]
  role_id bigint [not null]
  capability_id bigint [not null]
  condition_json text
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (role_id, capability_id) [unique]
  }
  Note: "Role-to-capability assignment"
}

Table user_roles {
  id bigint [pk, increment]
  user_id bigint [not null]
  role_id bigint [not null]
  granted_by_id bigint [not null]
  valid_from datetime(6) [not null]
  valid_to datetime(6)
  reason varchar(255) [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (user_id, valid_to)
    (role_id, valid_to)
  }
  Note: "Effective-dated user role assignment"
}

Table teams {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  code varchar(64) [unique, not null]
  name varchar(120) [not null]
  status varchar(20) [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  Note: "Staff team"
}

Table team_members {
  id bigint [pk, increment]
  team_id bigint [not null]
  user_id bigint [not null]
  member_role varchar(40) [not null]
  valid_from datetime(6) [not null]
  valid_to datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (team_id, valid_to)
    (user_id, valid_to)
  }
  Note: "Effective-dated team membership"
}

Table work_queues {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  code varchar(64) [unique, not null]
  name varchar(120) [not null]
  domain varchar(40) [not null]
  status varchar(20) [not null]
  assignment_policy_version_id bigint
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  Note: "Governed shared operational queue"
}

Table queue_memberships {
  id bigint [pk, increment]
  queue_id bigint [not null]
  user_id bigint [not null]
  can_claim boolean [not null, default: true]
  valid_from datetime(6) [not null]
  valid_to datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (queue_id, valid_to)
    (user_id, valid_to)
  }
  Note: "Queue eligibility and claim permissions"
}

Table delegations {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  delegator_id bigint [not null]
  delegatee_id bigint [not null]
  scope_json text [not null]
  starts_at datetime(6) [not null]
  ends_at datetime(6) [not null]
  reason varchar(255) [not null]
  revoked_at datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (delegatee_id, starts_at, ends_at)
  }
  Note: "Time-bounded delegation of work and allowed scope"
}

Table record_grants {
  id bigint [pk, increment]
  grantee_user_id bigint [not null]
  object_type varchar(64) [not null]
  object_id bigint [not null]
  grant_type varchar(32) [not null]
  valid_from datetime(6) [not null]
  valid_to datetime(6)
  granted_by_id bigint [not null]
  reason varchar(255) [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (grantee_user_id, object_type, object_id, valid_to)
  }
  Note: "Exceptional record-level access grant"
}

Table auth_events {
  id bigint [pk, increment]
  user_id bigint
  event_type varchar(48) [not null]
  outcome varchar(24) [not null]
  ip_prefix varchar(64)
  user_agent_hash char(64)
  correlation_id char(26) [not null]
  detail_json text [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (user_id, created_at)
    (event_type, created_at)
    (correlation_id)
  }
  Note: "Authentication and account-security event stream"
}

Table login_throttles {
  id bigint [pk, increment]
  bucket_hash char(64) [unique, not null]
  bucket_type varchar(24) [not null]
  failure_count int [not null]
  window_started_at datetime(6) [not null]
  blocked_until datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (blocked_until)
  }
  Note: "Database-backed authentication throttle buckets"
}

Table configuration_versions {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  scope varchar(64) [not null]
  version int [not null]
  status varchar(20) [not null]
  payload_json longtext [not null]
  checksum_sha256 char(64) [not null]
  created_by_id bigint [not null]
  reviewed_by_id bigint
  effective_from datetime(6)
  retired_at datetime(6)
  rollback_of_id bigint
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (scope, version) [unique]
    (scope, status, effective_from)
  }
  Note: "Immutable, checksummed configuration bundle version"
}

Table feature_flags {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  code varchar(96) [unique, not null]
  status varchar(20) [not null]
  scope_json text [not null]
  reason varchar(255) [not null]
  effective_from datetime(6) [not null]
  expires_at datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  Note: "Server-side feature flag with audited scope"
}

Table audit_events {
  id bigint [pk, increment]
  event_ulid char(26) [unique, not null]
  actor_type varchar(24) [not null]
  actor_user_id bigint
  effective_user_id bigint
  action varchar(96) [not null]
  object_type varchar(64) [not null]
  object_id bigint
  reason varchar(255)
  correlation_id char(26) [not null]
  before_hash char(64)
  after_hash char(64)
  diff_json longtext
  previous_event_hash char(64)
  event_hash char(64) [not null]

  indexes {
    (object_type, object_id, id)
    (actor_user_id, id)
    (correlation_id)
    (event_hash)
  }
  Note: "Append-only business/security audit evidence with hash chain"
}

Table audit_manifests {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  period_start datetime(6) [not null]
  period_end datetime(6) [not null]
  first_event_id bigint [not null]
  last_event_id bigint [not null]
  event_count bigint [not null]
  root_hash char(64) [not null]
  verified_at datetime(6) [not null]
  verification_result varchar(24) [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  Note: "Periodic audit-chain verification manifest"
}

Table privacy_cases {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  case_type varchar(32) [not null]
  status varchar(24) [not null]
  requester_contact_id bigint
  organization_id bigint
  owner_id bigint [not null]
  deadline_at datetime(6) [not null]
  scope_json text [not null]
  decision_json text
  completed_at datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (status, deadline_at)
    (organization_id, status)
  }
  Note: "Access/correction/restriction/deletion/objection/portability case"
}

Table legal_holds {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  scope_type varchar(32) [not null]
  scope_id bigint [not null]
  reason text [not null]
  authority varchar(255) [not null]
  starts_at datetime(6) [not null]
  ends_at datetime(6)
  review_at datetime(6) [not null]
  status varchar(20) [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (scope_type, scope_id, status)
    (review_at, status)
  }
  Note: "Retention override for defined records/entities"
}

Table organizations {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  name varchar(200) [not null]
  name_normalized varchar(200) [not null]
  domain_normalized varchar(253)
  lifecycle_state varchar(32) [not null]
  segment_code varchar(64)
  primary_owner_id bigint
  next_action_at datetime(6)
  manual_state_override varchar(32)
  override_expires_at datetime(6)
  data_quality_score decimal(5,2) [not null, default: 0]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  deleted_at datetime(6)
  deleted_by_id bigint

  indexes {
    (name_normalized)
    (domain_normalized)
    (lifecycle_state, primary_owner_id)
    (next_action_at)
  }
  Note: "Canonical organization/account/prospect identity"
}

Table contacts {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  given_name varchar(100) [not null]
  family_name varchar(100) [not null]
  display_name varchar(220) [not null]
  display_name_normalized varchar(220) [not null]
  lifecycle_state varchar(32) [not null]
  primary_owner_id bigint
  next_action_at datetime(6)
  data_quality_score decimal(5,2) [not null, default: 0]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  deleted_at datetime(6)
  deleted_by_id bigint

  indexes {
    (display_name_normalized)
    (lifecycle_state, primary_owner_id)
    (next_action_at)
  }
  Note: "Canonical person identity"
}

Table contact_organizations {
  id bigint [pk, increment]
  contact_id bigint [not null]
  organization_id bigint [not null]
  role_title varchar(160)
  relationship_role varchar(64) [not null]
  decision_influence varchar(32)
  is_primary boolean [not null, default: false]
  starts_at datetime(6) [not null]
  ends_at datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (contact_id, ends_at)
    (organization_id, ends_at)
    (organization_id, is_primary, ends_at)
  }
  Note: "Effective-dated contact-to-organization relationship"
}

Table contact_points {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  contact_id bigint
  organization_id bigint
  kind varchar(24) [not null]
  label varchar(40)
  value_display varchar(320) [not null]
  value_normalized varchar(320) [not null]
  is_primary boolean [not null, default: false]
  verification_state varchar(24) [not null]
  verified_at datetime(6)
  last_failure_at datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  deleted_at datetime(6)
  deleted_by_id bigint

  indexes {
    (kind, value_normalized)
    (contact_id, kind, is_primary)
    (organization_id, kind, is_primary)
  }
  Note: "Email, telephone, or channel address for a contact or organization"
}

Table addresses {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  contact_id bigint
  organization_id bigint
  address_type varchar(32) [not null]
  line1 varchar(200)
  line2 varchar(200)
  locality varchar(120)
  region varchar(120)
  postal_code varchar(32)
  country_code char(2)
  freeform text
  is_primary boolean [not null, default: false]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  deleted_at datetime(6)
  deleted_by_id bigint

  indexes {
    (organization_id, address_type, is_primary)
    (contact_id, address_type, is_primary)
  }
  Note: "Typed structured or free-form service address"
}

Table consent_preferences {
  id bigint [pk, increment]
  contact_id bigint [not null]
  contact_point_id bigint
  channel varchar(24) [not null]
  purpose_code varchar(64) [not null]
  decision varchar(24) [not null]
  lawful_basis varchar(64)
  evidence_source varchar(64) [not null]
  notice_version varchar(64)
  effective_at datetime(6) [not null]
  withdrawn_at datetime(6)
  evidence_json text [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (contact_id, channel, purpose_code, effective_at)
    (contact_point_id, purpose_code, effective_at)
  }
  Note: "Append-only purpose/channel communication preference evidence"
}

Table suppression_entries {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  contact_id bigint
  contact_point_id bigint
  channel varchar(24) [not null]
  purpose_code varchar(64)
  scope varchar(24) [not null]
  reason_code varchar(64) [not null]
  precedence smallint [not null]
  starts_at datetime(6) [not null]
  ends_at datetime(6)
  evidence_json text [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (contact_point_id, channel, purpose_code, ends_at)
    (contact_id, scope, ends_at)
  }
  Note: "Address/channel/purpose/global communication hold"
}

Table tags {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  code varchar(64) [unique, not null]
  name varchar(120) [not null]
  purpose varchar(255) [not null]
  allowed_object_types_json text [not null]
  status varchar(20) [not null]
  owner_id bigint [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  Note: "Governed tag definition"
}

Table entity_tags {
  id bigint [pk, increment]
  tag_id bigint [not null]
  object_type varchar(64) [not null]
  object_id bigint [not null]
  assigned_by_id bigint [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (object_type, object_id, tag_id) [unique]
    (tag_id, object_type)
  }
  Note: "Tag assignment to a supported business entity"
}

Table custom_field_definitions {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  code varchar(64) [not null]
  version int [not null]
  label varchar(120) [not null]
  data_type varchar(24) [not null]
  object_types_json text [not null]
  validation_json text [not null]
  visibility_class varchar(24) [not null]
  searchable boolean [not null, default: false]
  status varchar(20) [not null]
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (code, version) [unique]
    (status, code)
  }
  Note: "Versioned typed custom-field definition"
}

Table custom_field_values {
  id bigint [pk, increment]
  definition_id bigint [not null]
  object_type varchar(64) [not null]
  object_id bigint [not null]
  value_text text
  value_number decimal(30,8)
  value_datetime datetime(6)
  value_boolean boolean
  value_json text
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]

  indexes {
    (object_type, object_id, definition_id) [unique]
    (definition_id, value_number)
  }
  Note: "Typed custom-field value stored against one object"
}

Table file_assets {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  storage_key varchar(255) [unique, not null]
  original_filename varchar(255) [not null]
  mime_type varchar(127) [not null]
  size_bytes bigint [not null]
  sha256 char(64) [not null]
  classification varchar(24) [not null]
  validation_state varchar(24) [not null]
  retention_class varchar(64) [not null]
  uploaded_by_id bigint
  object_type varchar(64) [not null]
  object_id bigint [not null]
  archived_at datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  deleted_at datetime(6)
  deleted_by_id bigint

  indexes {
    (object_type, object_id)
    (sha256, size_bytes)
    (validation_state, created_at)
  }
  Note: "Private filesystem object metadata"
}

Table notes {
  id bigint [pk, increment]
  public_id char(26) [unique, not null]
  object_type varchar(64) [not null]
  object_id bigint [not null]
  author_id bigint [not null]
  category varchar(64) [not null]
  visibility varchar(24) [not null]
  body_text longtext [not null]
  amends_note_id bigint
  locked_at datetime(6)
  created_at datetime(6) [not null]
  updated_at datetime(6) [not null]
  row_version int [not null, default: 1]
  deleted_at datetime(6)
  deleted_by_id bigint

  indexes {
    (object_type, object_id, created_at)
    (author_id, created_at)
  }
  Note: "Structured note with explicit visibility and correction history"
}

Table timeline_events {
  id bigint [pk, increment]
  organization_id bigint
  contact_id bigint
  event_type varchar(64) [not null]
  source_type varchar(64) [not null]
  source_id bigint [not null]
  actor_type varchar(24) [not null]
  actor_id bigint
  visibility varchar(24) [not null]
  occurred_at datetime(6) [not null]
  summary varchar(500) [not null]
  correlation_id char(26) [not null]

  indexes {
    (organization_id, occurred_at)
    (contact_id, occurred_at)
