# Never commit real values. Production values live in cPanel Setup Python App environment variables.
ENVIRONMENT=production
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-64+-bytes-of-random-data
SIGNING_KEY_V1=replace-with-independent-random-key
ENCRYPTION_KEY_V1=replace-with-base64-aes-256-key
ACTIVE_SIGNING_KEY_VERSION=v1
ACTIVE_ENCRYPTION_KEY_VERSION=v1

APP_BASE_URL=https://crm.example.com
ALLOWED_HOSTS=crm.example.com
CSRF_TRUSTED_ORIGINS=https://crm.example.com
COMPANY_TIME_ZONE=Africa/Nairobi
BASE_CURRENCY=KES

DATABASE_ENGINE=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_NAME=cpuser_crm_prod
DATABASE_USER=cpuser_crm_app
DATABASE_PASSWORD=replace-me
DATABASE_CONN_MAX_AGE=30
DATABASE_OPTIONS_JSON={"charset":"utf8mb4"}

PRIVATE_STORAGE_ROOT=/home/cpuser/private/production
LOG_ROOT=/home/cpuser/private/production/logs
TEMP_ROOT=/home/cpuser/private/production/temp
STATIC_ROOT=/home/cpuser/public_html/crm-static

SMTP_CRM_HOST=mail.example.com
SMTP_CRM_PORT=465
SMTP_CRM_USE_SSL=true
SMTP_CRM_USERNAME=crm@example.com
SMTP_CRM_PASSWORD=replace-me
IMAP_CRM_HOST=mail.example.com
IMAP_CRM_PORT=993
IMAP_CRM_USE_SSL=true
IMAP_CRM_USERNAME=crm@example.com
IMAP_CRM_PASSWORD=replace-me

SMTP_SALES_USERNAME=sales@example.com
SMTP_SALES_PASSWORD=replace-me
IMAP_SALES_USERNAME=sales@example.com
IMAP_SALES_PASSWORD=replace-me
SMTP_SUPPORT_USERNAME=support@example.com
SMTP_SUPPORT_PASSWORD=replace-me
IMAP_SUPPORT_USERNAME=support@example.com
IMAP_SUPPORT_PASSWORD=replace-me
SMTP_FEEDBACK_USERNAME=feedback@example.com
SMTP_FEEDBACK_PASSWORD=replace-me
IMAP_FEEDBACK_USERNAME=feedback@example.com
IMAP_FEEDBACK_PASSWORD=replace-me

AUTOMATION_KILL_SWITCH=false
OUTBOX_HOURLY_LIMIT=60
OUTBOX_FIVE_MINUTE_LIMIT=10
JOB_BATCH_LIMIT=50
JOB_TIME_LIMIT_SECONDS=40
IMAP_BATCH_LIMIT=25
IMAP_TIME_LIMIT_SECONDS=35
DATABASE_WARNING_MB=300
DATABASE_CRITICAL_MB=375
DATABASE_EMERGENCY_MB=425
INODE_WARNING=180000
INODE_CRITICAL=220000
MIN_FREE_STORAGE_GB=8

RELEASE_IDENTIFIER=unconfigured
BUILD_COMMIT=unconfigured
CONFIG_BUNDLE_VERSION=unconfigured
